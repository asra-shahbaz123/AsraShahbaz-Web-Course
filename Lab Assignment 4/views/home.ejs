<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <title>Buy Coffee, Tea, Powders Online</title>
</head>
<body>
    <%- include('partials/navbar') %>
    <%- include('partials/flash') %>

    <div>
        <div class="Banner">
            <div class="BannerElements">
                <h1>Protein is here.</h1>
                <p>Your daily coffee ritual just got a boost.</p>
                <button class="bannerBtn" style="cursor: pointer;" onclick="window.location.href='/products'">ORDER NOW</button>
            </div>
        </div>
    </div>
    <div>
        <div class="centertext">
            <p>COFFEE, TEA, POWDERS & MORE</p>
            <h1>SHOP FOR HOME</h1>
        </div>
    </div>
    <div class="productBoxes">
        <div class="box" onclick="window.location.href='/products?category=Coffee'" style="cursor: pointer;">
            <img src="/CBTL_333_1.png" alt="Coffee Product">
            <div class="boxBlackText">COFFEE</div>
            <div class="boxPurpleText">SHOP COFFEE <i class="fa-solid fa-angle-down"></i></div>
        </div>
        <div class="box" onclick="window.location.href='/products?category=Tea'" style="cursor: pointer;">
            <img src="/Tea_HP_Coll.png" alt="Tea Product">
            <div class="boxBlackText">TEA</div>
            <div class="boxPurpleText">SHOP TEA <i class="fa-solid fa-angle-down"></i></div>
        </div>
        <div class="box" onclick="window.location.href='/products?category=Powders'" style="cursor: pointer;">
            <img src="/CBTL_333_3.png" alt="Powders Product">
            <div class="boxBlackText">POWDERS</div>
            <div class="boxPurpleText">SHOP POWDERS <i class="fa-solid fa-angle-down"></i></div>
        </div>
    </div>
    <div class="sfhbDiv">
        <button class="shopForHomeBtn" style="cursor: pointer;" onclick="window.location.href='/products'">SHOP FOR HOME</button>
    </div>
    <div class="ourLARoots">
        <div class="cbtlVideo">
            <img src="/CBTL_LA_Brew_Video.webp" alt="cbtl video">
        </div>
        <div class="ourLARootsText">
            <h1>OUR L.A. ROOTS</h1>
            <p>Founded by Herbert Hyman in 1963, The Coffee Bean & Tea Leaf opened its first store in Brentwood, Los Angeles, aiming to bring the best global coffee and tea to Southern California. Known for quality and excellence, they quickly became pioneers in California's gourmet coffee scene. Today, the core philosophy remains the same: crafting hand-made beverages with pride, from seed to cup.</p>
        </div>
    </div>
    <div>
        <div class="centertext">
            <p>BROWSE MENU & ORDER ONLINE FOR PICKUP</p>
            <h1>CAFE ORDERS</h1>
        </div>
    </div>
    <div class="productBoxes">
        <div class="box" onclick="window.location.href='/products'" style="cursor: pointer;">
            <img src="/Untitled_design_99.webp" alt="App Offer">
            <div class="boxBlackText">
                <h2>50% OFF YOUR FIRST DRINK</h2>
                <p style="font-weight:normal;">Download The Coffee Bean® Rewards app and enjoy member perks and exclusive offers today!</p>
            </div>
            <button class="pbBtn" style="cursor: pointer;" onclick="event.stopPropagation(); window.location.href='/register'">DOWNLOAD THE APP</button>
        </div>
        <div class="box" onclick="window.location.href='/products'" style="cursor: pointer;">
            <img src="/Square.webp" alt="Cafe Menu">
            <div class="boxBlackText">
                <h2>BROWSE CAFE MENU</h2>
                <p style="font-weight:normal;">Let your taste travel with every cup. Featuring our new Protein Lattes.</p>
            </div>
            <button class="pbBtn" style="cursor: pointer;" onclick="event.stopPropagation(); window.location.href='/products'">VIEW FULL MENU</button>
        </div>
        <div class="box" onclick="window.location.href='/checkout'" style="cursor: pointer;">
            <img src="/CBTL_Home_Col3.webp" alt="Start Order">
            <div class="boxBlackText">
                <h2>START CAFE ORDER</h2>
                <p style="font-weight:normal;">Enjoy your favorite The Coffee Bean & Tea Leaf drink in one of our local cafes or order supplies to make at home.</p>
            </div>
            <button class="pbBtn" style="cursor: pointer;" onclick="event.stopPropagation(); window.location.href='/checkout'">ORDER NOW</button>
        </div>
    </div>

    <div class="ourStorySection">
        <button class="ourStoryBtn" style="cursor: pointer;" onclick="window.location.href='/'">OUR STORY</button>
    </div>

    <div class="newsletterSection">
        <div class="newsletterLeft">
            <h2>SUBSCRIBE TO OUR NEWSLETTER</h2>
            <p>Join our email newsletter for 10% off your first order</p>
        </div>
        <div class="newsletterRight">
            <label>Your email</label>
            <div class="newsletterInputRow">
                <input type="email" class="newsletterInput" placeholder="">
                <button class="subscribeBtn">SUBSCRIBE</button>
            </div>
            <p class="newsletterDisclaimer">By selecting "Subscribe", you agree to the Coffee Bean and Tea Leaf Privacy Policy and Terms of Service. Unsubscribe from emails at any time. Please note when unsubscribing: it may take up to 10 business days for your request to take effect.</p>
        </div>
    </div>

    <footer class="footer">
        <div class="footerLogo">
            <img src="/cbtlLogo.png" alt="Coffee Bean Tea Leaf Logo">
        </div>
        <div class="footerColumn">
            <h3>Our Company</h3>
            <a href="#">Careers</a>
            <a href="#">Caring Cup</a>
            <a href="#">Franchising</a>
            <a href="#">Store Locator</a>
        </div>
        <div class="footerColumn">
            <h3>Site Terms</h3>
            <a href="#">Terms of Use</a>
            <a href="#">Privacy Policy</a>
            <a href="#">Cookie Policy</a>
            <a href="#">Do Not Sell or Share My Personal Information</a>
            <a href="#">Proposition 65</a>
        </div>
        <div class="footerColumn">
            <h3>Customer Care</h3>
            <a href="#">Contact Us</a>
            <a href="#">Returns</a>
            <a href="#">Shipping</a>
        </div>
    </footer>
</body>
</html>