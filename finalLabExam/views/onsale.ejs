<div class="centertext" style="margin-top: 40px;">
    <h1>ON-SALE PRODUCTS</h1>
    <p>Grab them before they're gone!</p>
</div>

<div id="product-list" class="productBoxes" style="display: flex; flex-wrap: wrap; justify-content: center; gap: 20px;">
    <% if (products.length > 0) { %>
        <% products.forEach(function(product) { %>
            <div class="box product-card" onclick="window.location.href='/products/<%= product._id %>'" style="cursor: pointer; display: none; position: relative; width: 260px; padding: 15px; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.08); background-color: #fff; transition: transform 0.2s ease;">
                <div style="position: absolute; top: 10px; right: 10px; background-color: #d11c1c; color: white; padding: 4px 8px; border-radius: 4px; font-weight: bold; font-size: 12px; box-shadow: 0 2px 5px rgba(0,0,0,0.2);">SALE</div>
                <img src="/<%= product.image %>" alt="<%= product.name %>" style="width: 100%; height: 200px; object-fit: contain; margin-bottom: 15px;">
                <div class="boxBlackText" style="text-align: center;">
                    <h2 style="font-size: 1.1em; margin: 0 0 10px 0;"><%= product.name %></h2>
                    <div>
                        <span style="text-decoration: line-through; color: #888; font-size: 0.9em; margin-right: 8px;">$<%= product.price %></span>
                        <span style="color: #d11c1c; font-weight: bold; font-size: 1.2em;">$<%= product.salePrice ? product.salePrice.toFixed(2) : (product.price * 0.8).toFixed(2) %></span>
                    </div>
                </div>
            </div>
        <% }); %>
    <% } else { %>
        <p>No products on sale currently.</p>
    <% } %>
</div>

<div id="pagination-controls" style="text-align: center; margin: 40px 0;">
    <button id="prev-btn" class="shopForHomeBtn" style="cursor: pointer; padding: 10px 20px;">Previous</button>
    <span id="page-indicator" style="margin: 0 15px; font-weight: bold; font-size: 1.1em;">Page 1 of 1</span>
    <button id="next-btn" class="shopForHomeBtn" style="cursor: pointer; padding: 10px 20px;">Next</button>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function() {
        var $products = $('.product-card');
        var totalProducts = $products.length;
        var limit = 10;
        var totalPages = Math.ceil(totalProducts / limit);
        var currentPage = 1;

        if (totalProducts === 0) {
            $('#pagination-controls').hide();
            return;
        }

        if (totalPages === 0) totalPages = 1;

        function updateView() {
            var startIndex = (currentPage - 1) * limit;
            var endIndex = startIndex + limit;

            // Hide all products first
            $products.hide();

            // Show the current chunk
            $products.slice(startIndex, endIndex).show();

            // Update page indicator
            $('#page-indicator').text('Page ' + currentPage + ' of ' + totalPages);

            // Button visibility/disabling logic
            if (currentPage <= 1) {
                $('#prev-btn').prop('disabled', true).css('opacity', '0.5');
            } else {
                $('#prev-btn').prop('disabled', false).css('opacity', '1');
            }

            if (currentPage >= totalPages) {
                $('#next-btn').prop('disabled', true).css('opacity', '0.5');
            } else {
                $('#next-btn').prop('disabled', false).css('opacity', '1');
            }
        }

        // Initialize view
        updateView();

        // Next button click event
        $('#next-btn').click(function() {
            if (currentPage < totalPages) {
                currentPage++;
                updateView();
            }
        });

        // Previous button click event
        $('#prev-btn').click(function() {
            if (currentPage > 1) {
                currentPage--;
                updateView();
            }
        });
    });
</script>