<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 0; padding: 0; display: flex; }
        .sidebar { width: 250px; background: #333; color: #fff; min-height: 100vh; padding: 20px; }
        .sidebar h2 { color: #fff; }
        .sidebar a { color: #bbb; text-decoration: none; display: block; margin: 10px 0; }
        .sidebar a:hover { color: #fff; }
        .content { flex: 1; padding: 20px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background-color: #f2f2f2; }
        .btn { padding: 5px 10px; text-decoration: none; border: none; cursor: pointer; color: #fff; border-radius: 4px; }
        .btn-add { background: #28a745; margin-bottom: 20px; display: inline-block; }
        .btn-edit { background: #007bff; }
        .btn-delete { background: #dc3545; }
        .actions { display: flex; gap: 5px; }
        form { display: inline; }
    </style>
</head>
<body>
    <div class="sidebar">
        <h2>Admin Panel</h2>
        <a href="/">Go to Store</a>
        <a href="/admin">Dashboard</a>
        <a href="/admin/products/new">Add Product</a>
    </div>
    <div class="content">
        <h1>Product Management</h1>
        <a href="/admin/products/new" class="btn btn-add">Add New Product</a>
        
        <table>
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% products.forEach(product => { %>
                <tr>
                    <td>
                        <img src="<%= product.image.startsWith('/') ? product.image : '/' + product.image %>" alt="<%= product.name %>" width="50" height="50" style="object-fit: cover;">
                    </td>
                    <td><%= product.name %></td>
                    <td><%= product.category %></td>
                    <td>$<%= product.price %></td>
                    <td><%= product.stock %></td>
                    <td class="actions">
                        <a href="/admin/products/<%= product._id %>/edit" class="btn btn-edit">Edit</a>
                        <form action="/admin/products/<%= product._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this product?');">
                            <button type="submit" class="btn btn-delete">Delete</button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>