<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <title>Admin Panel | Coffee Bean & Tea Leaf</title>
    <style>
        .adminWrap {
            max-width: 1000px;
            margin: 50px auto;
            padding: 30px;
            font-family: sans-serif;
        }
        .adminWrap h1, .adminWrap h2 { color: #532D6D; margin-top: 30px;}
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        th, td {
            padding: 12px 15px;
            border: 1px solid #ddd;
            text-align: left;
            font-size: 14px;
        }
        th { background-color: #532D6D; color: white; }
        tr:nth-child(even) { background-color: #f9f9f9; }
        .btn { padding: 5px 10px; text-decoration: none; border: none; cursor: pointer; color: #fff; border-radius: 4px; }
        .btn-add { background: #28a745; margin-bottom: 20px; display: inline-block; }
        .btn-edit { background: #007bff; }
        .btn-delete { background: #dc3545; }
        .actions { display: flex; gap: 5px; }
        form { display: inline; }
    </style>
</head>
<body>
    <%- include('partials/navbar') %>
    <%- include('partials/flash') %>
    <div class="adminWrap">
        <h1>ADMIN PANEL</h1>
        <p>Logged in as: <strong><%= session.userName %></strong></p>
        
        <h2>All Users</h2>
        <table>
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(u => { %>
                <tr>
                    <td><%= u.name %></td>
                    <td><%= u.email %></td>
                    <td><%= u.role %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>

        <h2>Product Management</h2>
        <a href="/admin/products/new" class="btn btn-add">Add New Product</a>
        
        <table>
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Name</th>
                    <th>Category</th>
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% products.forEach(product => { %>
                <tr>
                    <td>
                        <img src="<%= product.image.startsWith('/') ? product.image : '/' + product.image %>" alt="<%= product.name %>" width="50" height="50" style="object-fit: cover;">
                    </td>
                    <td><%= product.name %></td>
                    <td><%= product.category %></td>
                    <td>$<%= product.price %></td>
                    <td><%= product.stock %></td>
                    <td class="actions">
                        <a href="/admin/products/<%= product._id %>/edit" class="btn btn-edit">Edit</a>
                        <form action="/admin/products/<%= product._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this product?');">
                            <button type="submit" class="btn btn-delete">Delete</button>
                        </form>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</body>
</html>
